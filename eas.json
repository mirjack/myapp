{
  "cli": {
    "version": ">= 7.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_WEB_URL": "https://mirjeck.cmfrt.uz/",
        "EXPO_PUBLIC_API_BASE_URL": "https://stg-api.cmfrt.uz",
        "EXPO_PUBLIC_TENANT_DOMAIN": "mirjeck.cmfrt.uz"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_WEB_URL": "https://mirjeck.cmfrt.uz/",
        "EXPO_PUBLIC_API_BASE_URL": "https://stg-api.cmfrt.uz",
        "EXPO_PUBLIC_TENANT_DOMAIN": "mirjeck.cmfrt.uz"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_WEB_URL": "https://mirjeck.cmfrt.uz/",
        "EXPO_PUBLIC_API_BASE_URL": "https://api.cmfrt.uz",
        "EXPO_PUBLIC_TENANT_DOMAIN": "mirjeck.cmfrt.uz"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
